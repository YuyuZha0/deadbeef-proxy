<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <!-- encoders are assigned the type
             ch.qos.logback.classic.encoder.PatternLayoutEncoder by default -->
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <!--            <pattern>%logger{36} - %msg%n</pattern>-->
        </encoder>
    </appender>

    <!-- Vert.x logs "Connection was closed" at ERROR whenever a peer drops the TCP socket
         after a normal HTTP response. That happens on every test that ends with a non-2xx
         response, swamping CI output with non-actionable noise. -->
    <logger name="io.vertx.core.http.impl.HttpClientRequestImpl" level="OFF"/>

    <root level="debug">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>