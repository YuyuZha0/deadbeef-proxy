<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <!-- encoders are assigned the type
             ch.qos.logback.classic.encoder.PatternLayoutEncoder by default -->
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <!--            <pattern>%logger{36} - %msg%n</pattern>-->
        </encoder>
    </appender>

    <!-- Drop Vert.x's "Connection was closed" ERROR — it fires on every normal non-2xx
         response close and adds no diagnostic value. -->
    <logger name="io.vertx.core.http.impl.HttpClientRequestImpl" level="OFF"/>

    <root level="debug">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>